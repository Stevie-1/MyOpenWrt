# 默认行为：自动识别文本，统一 LF
* text=auto eol=lf

# ===== 强制 LF（在 OpenWrt 上跑的，碰 CRLF 必炸） =====
*.sh    text eol=lf
*.bash  text eol=lf

# ===== 源码统一 LF =====
*.c     text eol=lf
*.h     text eol=lf
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.vue   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.conf  text eol=lf
Makefile        text eol=lf
Makefile.*      text eol=lf

# ===== Windows 专用，必须 CRLF =====
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# ===== 二进制（不做 diff，不做换行符转换） =====
*.docx  binary
*.xlsx  binary
*.pptx  binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.mp4   binary
*.mov   binary
*.mp3   binary
*.zip   binary
*.rar   binary
*.7z    binary
*.tar   binary
*.gz    binary
*.tgz   binary
*.zst   binary
*.exe   binary
*.dll   binary
*.so    binary
*.a     binary
*.o     binary
*.vmdk  binary
*.img   binary
*.iso   binary
*.pcap  binary
*.pcapng binary

# ===== Lock 文件（diff 噪音大，由工具维护，team review 时折叠） =====
pnpm-lock.yaml  linguist-generated=true
package-lock.json linguist-generated=true
yarn.lock       linguist-generated=true
poetry.lock     linguist-generated=true
